
# Model configuration (optional)
# Default model for routine tasks (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6
# Escalation model for research/council subagents (default: opus)
# Accepts: opus, sonnet, haiku
CLAUDE_ESCALATION_MODEL=opus
# Extended thinking token budget (default: 16384)
CLAUDE_MAX_THINKING_TOKENS=16384

